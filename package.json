{
    "name": "nexgen-launchpad",
    "displayName": "Launchpad",
    "description": "The Extension Publishing Control Center. Validate, audit, and ship your VS Code extensions with one click.",
    "version": "0.1.3",
    "publisher": "NexGenSynapse",
    "repository": {
        "type": "git",
        "url": "https://github.com/AlwayzPoppin/LaunchPad"
    },
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "launchpad-explorer",
                    "title": "Launchpad",
                    "icon": "media/icon.png"
                }
            ]
        },
        "views": {
            "launchpad-explorer": [
                {
                    "type": "webview",
                    "id": "launchpad.controlPanel",
                    "name": "Control Panel"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "18.x",
        "typescript": "^5.3.3",
        "ts-loader": "^9.5.1",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    }
}